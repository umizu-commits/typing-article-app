<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "ReadTyping" %></title>
    <meta name="viewport" content="width=1280">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 min-w-[1280px] h-screen flex flex-col">
    <header class="w-full bg-white border-b border-gray-200">
      <div class="container mx-auto px-5 h-14 flex items-center justify-between">
        <%= link_to "ReadTyping", root_path, class: "text-blue-600 font-bold text-lg" %>
        <nav class="flex items-center gap-3">
          <% if user_signed_in? %>
            <%= link_to "履歴", typing_histories_path, class: "text-gray-600 text-sm hover:text-blue-600" %>
            <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "bg-blue-600 text-white px-4 py-2 rounded-lg text-sm" %>
          <% else %>
            <%= link_to "新規登録", new_user_registration_path, class: "text-gray-600 text-sm hover:text-blue-600" %>
            <%= link_to "ログイン", new_user_session_path, class: "bg-blue-600 text-white px-4 py-2 rounded-lg text-sm" %>
          <% end %>
        </nav>
      </div>
    </header>
    <main class="flex-1 container mx-auto px-5">
      <!-- ログイン系のフラッシュメッセージ -->
      <% if notice.present? %>
        <div class="mt-4 rounded-lg bg-green-100 px-4 py-3 text-sm text-green-700">
          <%= notice %>
        </div>
      <% end %>

      <% if alert.present? %>
        <div class="mt-4 rounded-lg bg-red-100 px-4 py-3 text-sm text-red-700">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
    <footer class="border-t border-gray-200 bg-white">
      <div class="container mx-auto px-5 py-6 text-center text-sm text-gray-400">
        &copy; 2026 ReadTyping
      </div>
    </footer>
  </body>
</html>
