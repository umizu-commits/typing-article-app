<div class="flex items-center justify-center flex-1">
  <div class="w-[400px] rounded-xl bg-white p-8 shadow-sm space-y-6">
    <h1 class="text-xl font-bold text-gray-800 text-center">ログイン</h1>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="space-y-4">
        <div>
          <p class="text-sm font-bold text-gray-700 mb-1">メールアドレス</p>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "w-full rounded-lg border border-gray-300 px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" %>
        </div>

        <div>
          <p class="text-sm font-bold text-gray-700 mb-1">パスワード</p>
          <%= f.password_field :password,
              autocomplete: "current-password",
              class: "w-full rounded-lg border border-gray-300 px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" %>
        </div>
      </div>

      <%= f.submit "ログイン",
          class: "w-full mt-6 rounded-lg bg-blue-400 px-6 py-3 font-bold text-white shadow-sm hover:bg-blue-500 cursor-pointer" %>
    <% end %>

    <div class="text-center text-sm text-gray-500">
      アカウントをお持ちでない方は
      <%= link_to "新規登録", new_user_registration_path, class: "text-blue-500 hover:underline" %>
    </div>
  </div>
</div>
