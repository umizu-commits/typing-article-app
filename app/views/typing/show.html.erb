<div data-controller="typing" class="h-[calc(100vh-128px)] overflow-hidden py-3">
  <div class="grid h-full grid-cols-[1fr_320px] gap-6 overflow-hidden">
    <%# テキスト表示エリア %>
    <section class="relative overflow-hidden rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <p
        data-typing-target="text"
        class="h-full overflow-auto whitespace-pre-wrap break-words text-lg font-semibold leading-relaxed text-gray-800 cursor-text"
        data-action="click->typing#focusInput"
      >
      </p>

      <textarea
        data-typing-target="input"
        data-action="keydown->typing#handleKeydown"
        class="absolute opacity-0"
        autocomplete="off"
        spellcheck="false"></textarea>
    </section>

    <%# 右側エリア %>
    <aside class="flex h-full flex-col items-end justify-between overflow-hidden">
      <div class="w-[260px] rounded-xl bg-white p-4 text-center shadow-sm">
        <div class="text-xs font-bold text-gray-500">
          経過時間
        </div>

        <div
          data-typing-target="timer"
          class="mt-1 font-mono text-2xl font-bold text-gray-900"
        >
          00:00
        </div>
      </div>

      <div
        data-typing-target="hint"
        class="w-[260px] rounded-xl bg-blue-50 border border-blue-200 p-4 text-center text-sm text-blue-600">
        最初の文字を入力すると<br>タイマーが開始されます
      </div>

      <button
        type="button"
        data-action="click->typing#reset"
        class="w-[260px] rounded-full bg-white border border-gray-300 px-6 py-3 font-bold text-gray-700 shadow-sm hover:bg-gray-50">
        再挑戦する
        </button>

      <button
        type="button"
        class="w-[260px] rounded-full bg-blue-400 px-6 py-3 font-bold text-white shadow-sm hover:bg-blue-500"
      >
        タイピングを終了する →
      </button>
    </aside>
  </div>
</div>