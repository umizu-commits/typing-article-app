<div data-controller="result" class="py-10 px-4">

  <%# 完了メッセージ %>
  <div class="text-center mb-8">
    <div class="text-6xl mb-4">🏆</div>
    <h1 class="text-3xl font-bold text-gray-800 mb-2">練習完了！お疲れ様でした。</h1>
    <p class="text-sm text-gray-500">タイピングを最後まで完了しました。</p>
  </div>

  <%# 結果スタッツ %>
  <div class="flex justify-center gap-4 mb-6 max-w-4xl mx-auto">

    <%# 正答率 %>
    <div class="flex-1 rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <div class="flex items-center gap-2 mb-3">
        <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
          <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="text-xs font-bold text-gray-500">正答率</div>
      </div>
      <div data-result-target="accuracy" class="text-3xl font-bold text-gray-900 text-center">--%</div>
    </div>

    <%# 文字/分 %>
    <div class="flex-1 rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <div class="flex items-center gap-2 mb-3">
        <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center">
          <svg class="w-4 h-4 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <div class="text-xs font-bold text-gray-500">CPM（文字/分）</div>
      </div>
      <div data-result-target="cpm" class="text-3xl font-bold text-gray-900 text-center">--</div>
    </div>

    <%# WPM目安 %>
    <div class="flex-1 rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <div class="flex items-center gap-2 mb-3">
        <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
          <svg class="w-4 h-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
        <div class="text-xs font-bold text-gray-500">WPM目安</div>
      </div>
      <div data-result-target="wpm" class="text-3xl font-bold text-gray-900 text-center">--</div>
    </div>

    <%# 経過時間 %>
    <div class="flex-1 rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <div class="flex items-center gap-2 mb-3">
        <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
          <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="text-xs font-bold text-gray-500">経過時間</div>
      </div>
      <div data-result-target="elapsedTime" class="text-3xl font-bold text-gray-900 text-center">--:--</div>
    </div>

    <%# ミス数 %>
    <div class="flex-1 rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <div class="flex items-center gap-2 mb-3">
        <div class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center">
          <svg class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <div class="text-xs font-bold text-gray-500">ミス数</div>
      </div>
      <div data-result-target="missCount" class="text-3xl font-bold text-gray-900 text-center">--</div>
    </div>

  </div>

  <%# 保存成功 %>
  <div data-result-target="saveSuccess" class="hidden max-w-2xl mx-auto rounded-xl bg-green-50 border border-green-200 p-4 text-center text-sm text-green-700">
    結果を保存しました
  </div>

  <%# 保存失敗 %>
  <div data-result-target="saveFailed" class="hidden max-w-2xl mx-auto rounded-xl bg-red-50 border border-red-200 p-4 text-center text-sm text-red-700">
    結果の保存に失敗しました
  </div>

  <%# ナビゲーションボタン %>
  <div class="flex justify-center gap-3 mt-10 mb-8">
    <%= link_to "同じテキストで再度練習", typing_path,
        class: "inline-flex items-center justify-center min-w-[200px] rounded-lg bg-blue-400 hover:bg-blue-500 px-6 py-3 font-bold text-white shadow-sm" %>

    <button
      type="button"
      data-action="click->result#goToTop"
      class="min-w-[200px] rounded-lg bg-white border border-gray-300 px-6 py-3 font-bold text-gray-700 shadow-sm hover:bg-gray-50">
      異なるテキストで練習
    </button>

    <% if user_signed_in? %>
      <%= link_to "履歴を見る", typing_histories_path,
          class: "inline-flex items-center justify-center min-w-[200px] rounded-lg bg-white border border-gray-300 px-6 py-3 font-bold text-gray-700 shadow-sm hover:bg-gray-50" %>
    <% end %>
  </div>

  <%# 未ログイン（スキップ） %>
  <div data-result-target="saveSkipped" class="hidden max-w-2xl mx-auto rounded-xl bg-blue-50 border border-blue-200 p-5 flex items-center justify-between gap-4">
    <div>
      <p class="font-bold text-gray-800">タイピングの成長を記録しませんか？</p>
      <p class="text-xs text-gray-500 mt-1">ログインすると結果が保存され、履歴を確認できます</p>
    </div>
    <div class="flex gap-2 shrink-0">
      <%= link_to "ログイン", new_user_session_path,
          class: "rounded-lg bg-blue-400 px-5 py-2 font-bold text-white text-sm hover:bg-blue-500" %>
      <%= link_to "新規登録", new_user_registration_path,
          class: "rounded-lg bg-white border border-blue-400 px-5 py-2 font-bold text-blue-500 text-sm hover:bg-blue-50" %>
    </div>
  </div>

</div>
